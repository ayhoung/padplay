{
  "name": "@padplay/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "migrate": "tsx src/scripts/migrate.ts",
    "seed": "tsx src/scripts/seed.ts",
    "refresh-ratings": "tsx src/scripts/refresh-ratings.ts",
    "check-integrity": "tsx src/scripts/check-integrity.ts",
    "propose-fixes": "tsx src/scripts/propose-fixes.ts",
    "apply-fixes": "tsx src/scripts/apply-fixes.ts",
    "add-games": "tsx src/scripts/add-games.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1036.0",
    "@padplay/shared-types": "workspace:*",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "google-play-scraper": "^10.0.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.18.0",
    "eslint": "^8.57.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
